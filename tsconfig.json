{
  "compilerOptions": {
    "target": "ES2015",
    "module": "ES6",
    "outDir": "./scripts",
    "rootDir": "./",
    "strict": true,
    "esModuleInterop": true,
    "forceConsistentCasingInFileNames": true,
    "skipLibCheck": true
  },
  "include": ["./*.ts"],
  "exclude": ["node_modules", "scripts"]
}